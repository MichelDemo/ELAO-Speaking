# Azure Speech Services - https://portal.azure.com/
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westeurope

# Anthropic - https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Modèle Claude (Sonnet 4.5 = bon compromis qualité/latence pour conversation)
ANTHROPIC_MODEL=claude-sonnet-4-5

# Avaturn 3-D avatar — paste the GLB URL from your Avaturn export
# Free tier: 100 exports/month · avaturn.me
NEXT_PUBLIC_AVATURN_URL=

# HeyGen Streaming Avatar — https://app.heygen.com/avatar
# Set NEXT_PUBLIC_HEYGEN_ENABLED=true to replace the 3-D/SVG avatar with a
# photorealistic HeyGen avatar. Requires a HeyGen API key and an avatar ID.
# Avatar IDs are found in the HeyGen dashboard under "Avatars".
# Cost: ~1 credit/minute of session time.
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
NEXT_PUBLIC_HEYGEN_ENABLED=false
